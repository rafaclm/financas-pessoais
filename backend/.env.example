# ==========================================
# Configuracao do Sistema Financas Pessoais
# ==========================================
# Este e um arquivo MODELO. Copie para .env e preencha com seus valores reais.

# App
APP_NAME=Financas Pessoais
APP_HOST=0.0.0.0
APP_PORT=8080
LOG_LEVEL=INFO

# Banco de Dados
# SQLite (desenvolvimento):
# DATABASE_URL=sqlite:///./data/financas.db
# PostgreSQL (producao):
DATABASE_URL=postgresql+psycopg2://usuario:senha@host:5432/nomedobanco

# CORS (URLs permitidas, separadas por virgula)
# Localhost para dev, sua URL Vercel para producao
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Autenticacao
SECRET_KEY=gere-uma-chave-super-secreta-com-python-secrets
CODIGO_CADASTRO=escolha-um-codigo-secreto
JWT_EXPIRE_DAYS=7

# Integracoes externas
BRAPI_TOKEN=